---
interface Props {
  title: string;
  fonts?: string[];
  accentColor?: string;
  ogImage?: string;
  ogDescription?: string;
}

const { title, fonts = [], accentColor = '#7c3aed', ogImage, ogDescription } = Astro.props;

import { photosPublished, EVENT } from '../config';
import '../styles/global.css';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const showPhotos = photosPublished || import.meta.env.DEV;

const googleFontsUrl = fonts.length > 0
  ? `https://fonts.googleapis.com/css2?${fonts.map(f => `family=${f.replace(/ /g, '+')}`).join('&')}&display=swap`
  : null;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{import.meta.env.DEV ? '(dev) ' : ''}{title} — BBQ Invitations</title>
  <meta property="og:title" content={`${title} — BBQ Invitations`} />
  <meta property="og:type" content="website" />
  {ogDescription && <meta property="og:description" content={ogDescription} />}
  {ogImage && <meta property="og:image" content={`${Astro.site}${ogImage.replace(/^\//, '')}`} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Anton&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Inconsolata:wght@400;700&family=Space+Mono:wght@400;700&family=DM+Mono:wght@400;500&display=swap" />
  {googleFontsUrl && <link rel="stylesheet" href={googleFontsUrl} />}
  <style define:vars={{ accentColor }}>
    /* CSS custom properties — needed for define:vars and per-page accent overrides */
    :root {
      --accent:       var(--accentColor);
      --brand:        #7c3aed;
    }

    /* Scroll state — JS toggles .scrolled, Tailwind can't express this */
    .site-header { transition: background 0.2s, border-color 0.2s; }
    .site-header.scrolled { background: #0a0a0add; border-color: #0a0a0a; }
    .site-header.scrolled .site-logo { color: #ffffff; }
    .site-header.scrolled .site-nav a { color: #999; }
    .site-header.scrolled .site-nav a:hover { color: var(--accent); }
    .site-header.scrolled .nav-cta { background: var(--brand); color: #ccc; }
  </style>
</head>
<body class="bg-white text-ink font-body leading-[1.7] min-h-screen">
  <header class="site-header flex items-center justify-between px-8 h-14 border-b-site border-border sticky top-0 bg-white z-[100]">
    <a href={base} class="site-logo font-display text-[22px] tracking-[0.08em] text-ink no-underline hover:no-underline">BBQ<span class="text-accent">.</span>INVITATIONS</a>
    <nav class="site-nav flex items-center gap-8 font-mono text-xs tracking-[0.12em] uppercase" aria-label="Site navigation">
      <a href={`${base}#styles`} class="text-[#777] no-underline hover:text-accent hover:no-underline">All Invitations</a>
      {!photosPublished && <a href={EVENT.foodSignupUrl} target="_blank" rel="noopener noreferrer" class="text-[#777] no-underline hover:text-accent hover:no-underline">Food Sign-Up</a>}
      {showPhotos && <a href={EVENT.photosUrl} target="_blank" rel="noopener noreferrer" class="text-[#777] no-underline hover:text-accent hover:no-underline">Photos</a>}
      <a href={`${base}rsvp`} class="nav-cta bg-brand text-white py-1 px-3 tracking-[0.14em] hover:opacity-[0.88] hover:text-white hover:no-underline">RSVP</a>
    </nav>
  </header>

  <main class="max-w-site mx-auto px-8 pt-12 pb-24">
    <slot />
  </main>

  <footer class="border-t-site border-border py-5 px-8 flex justify-between items-center">
    <div class="font-mono text-[10px] tracking-[0.12em] uppercase text-ink-muted">Boston Magic Lab · Felice & the Production Staff · 2026</div>
    <div class="font-display text-base tracking-[0.1em] text-accent">Jeannine at the grill.</div>
  </footer>

  <script>
    const header = document.querySelector('.site-header');
    if (header) {
      window.addEventListener('scroll', () => {
        header.classList.toggle('scrolled', window.scrollY > 10);
      }, { passive: true });
    }
  </script>
</body>
</html>
