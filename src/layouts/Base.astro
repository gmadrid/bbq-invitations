---
interface Props {
  title: string;
  fonts?: string[];
  accentColor?: string;
}

const { title, fonts = [], accentColor = '#7c3aed' } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const googleFontsUrl = fonts.length > 0
  ? `https://fonts.googleapis.com/css2?${fonts.map(f => `family=${f.replace(/ /g, '+')}`).join('&')}&display=swap`
  : null;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — BBQ Invitations</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Anton&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Inconsolata:wght@400;700&family=Space+Mono:wght@400;700&family=DM+Mono:wght@400;500&display=swap" />
  {googleFontsUrl && <link rel="stylesheet" href={googleFontsUrl} />}
  <style define:vars={{ accentColor }}>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --accent:       var(--accentColor);
      --bg:           #ffffff;
      --ink:          #0a0a0a;
      --ink-soft:     #444444;
      --ink-muted:    #999999;
      --border:       #0a0a0a;
      --border-light: #e0e0e0;
      --border-width: 2px;
      --max-width:    900px;
      --font-display: 'Anton', Impact, sans-serif;
      --font-body:    'Libre Baskerville', Georgia, serif;
      --font-mono:    'Inconsolata', 'Courier New', monospace;
    }

    html { font-size: 16px; }

    body {
      background: var(--bg);
      color: var(--ink);
      font-family: var(--font-body);
      line-height: 1.7;
      min-height: 100vh;
    }

    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }

    .site-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2rem;
      height: 56px;
      border-bottom: var(--border-width) solid var(--border);
      position: sticky;
      top: 0;
      background: var(--bg);
      z-index: 100;
    }

    .site-logo {
      font-family: var(--font-display);
      font-size: 22px;
      letter-spacing: 0.08em;
      color: var(--ink);
      text-decoration: none;
    }

    .site-logo:hover { text-decoration: none; }
    .site-logo-dot { color: var(--accent); }

    .site-nav {
      display: flex;
      gap: 2rem;
      font-family: var(--font-mono);
      font-size: 12px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .site-nav a { color: #777777; text-decoration: none; }
    .site-nav a:hover { color: var(--accent); text-decoration: none; }

    main {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 3rem 2rem 6rem;
    }

    .site-footer {
      border-top: var(--border-width) solid var(--border);
      padding: 1.25rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .site-footer-left {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--ink-muted);
    }

    .site-footer-right {
      font-family: var(--font-display);
      font-size: 16px;
      letter-spacing: 0.1em;
      color: var(--accent);
    }

    :global(.eyebrow) {
      font-family: var(--font-mono);
      font-size: 12px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.75rem;
      display: block;
    }
  </style>
</head>
<body>
  <header class="site-header">
    <a href={base} class="site-logo">BBQ<span class="site-logo-dot">.</span>INVITATIONS</a>
    <nav class="site-nav">
      <a href={`${base}#styles`}>All Styles</a>
      <a href={`${base}rsvp`}>RSVP</a>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="site-footer-left">Boston Magic Lab · Felice & the Founders · 2026</div>
    <div class="site-footer-right">Jeannine at the grill.</div>
  </footer>
</body>
</html>
