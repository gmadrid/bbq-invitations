---
import Base from '../layouts/Base.astro';
import { EVENT } from '../config';
---
<Base title="RSVP">
  <style>
    /* Form input styles — Tailwind's form plugin could handle these, but keeping explicit for control */
    .rsvp-input {
      @apply block w-full box-border font-body text-base py-[0.6rem] px-3 border-site border-border bg-white text-ink outline-none appearance-none;
    }
    .rsvp-input:focus {
      border-color: var(--accent);
    }

    /* Custom radio buttons — pseudo-elements need CSS */
    .rsvp-radio {
      @apply w-4 h-4 appearance-none border-site border-border rounded-full bg-white cursor-pointer relative shrink-0;
    }
    .rsvp-radio:checked {
      border-color: var(--accent);
      background: var(--accent);
    }
    .rsvp-radio:checked::after {
      content: '';
      @apply absolute top-[3px] left-[3px] w-[6px] h-[6px] bg-white rounded-full;
    }

    /* Label style used in field context */
    .rsvp-label {
      @apply block font-mono text-[10px] tracking-[0.2em] uppercase text-ink-muted mb-[0.4rem];
    }
  </style>

  <div class="max-w-[560px] mx-auto">
    <div class="font-mono text-[0.65rem] tracking-[0.3em] uppercase text-ink-muted mb-4">Boston Magic Lab · 2026</div>
    <h1 class="font-display text-5xl font-black leading-[1.1] mb-4">RSVP</h1>
    <p class="text-base text-ink-soft leading-[1.8] mb-10 italic">
      We'd love to know you're coming. Jeannine would also love to know —
      it helps with the coals.
    </p>

    <dl class="border-site border-border border-t-[3px] border-t-accent py-6 px-8 mb-10 text-[0.95rem] leading-8">
      <dt class="font-mono text-[0.65rem] tracking-[0.25em] uppercase text-ink-muted mt-4 first:mt-0">When</dt>
      <dd class="text-ink m-0">{EVENT.date}</dd>
      <dt class="font-mono text-[0.65rem] tracking-[0.25em] uppercase text-ink-muted mt-4">Where</dt>
      <dd class="text-ink m-0">{EVENT.address} · {EVENT.addressLine2}</dd>
      <dt class="font-mono text-[0.65rem] tracking-[0.25em] uppercase text-ink-muted mt-4">Bring</dt>
      <dd class="text-ink m-0">Food or drink to share · Coordination forthcoming</dd>
      <dt class="font-mono text-[0.65rem] tracking-[0.25em] uppercase text-ink-muted mt-4">BBQ Dad</dt>
      <dd class="text-ink m-0">Jeannine</dd>
    </dl>

    <form class="flex flex-col gap-6 [&.hidden]:hidden" id="rsvp-form">
      <div>
        <label for="name" class="rsvp-label">Your Name</label>
        <input type="text" id="name" name="name" required class="rsvp-input" />
      </div>

      <fieldset class="border-none p-0 m-0">
        <legend class="rsvp-label p-0">Are You Coming?</legend>
        <div class="flex gap-6 mt-[0.3rem]">
          <label class="flex items-center gap-[0.4rem] font-body text-base italic text-ink tracking-normal normal-case cursor-pointer">
            <input type="radio" name="attending" value="yes" required class="rsvp-radio" /> Yes
          </label>
          <label class="flex items-center gap-[0.4rem] font-body text-base italic text-ink tracking-normal normal-case cursor-pointer">
            <input type="radio" name="attending" value="no" class="rsvp-radio" /> Regretfully, no
          </label>
        </div>
      </fieldset>

      <div class="flex flex-col gap-6 [&.hidden]:hidden" id="rsvp-attending-fields">
        <div>
          <label for="guests" class="rsvp-label">Total Guests (Including You)</label>
          <select id="guests" name="guests" class="rsvp-input">
            <option value="1">1</option>
            <option value="2">2</option>
            <option value="3">3</option>
            <option value="4">4</option>
            <option value="5+">5+</option>
          </select>
        </div>

        <div>
          <label for="kids" class="rsvp-label">Any Kids?</label>
          <select id="kids" name="kids" class="rsvp-input">
            <option value="0">No kids</option>
            <option value="1">1</option>
            <option value="2">2</option>
            <option value="3">3</option>
            <option value="4+">4+</option>
          </select>
        </div>
      </div>

      <div>
        <label for="dietary" class="rsvp-label">Dietary Restrictions (Optional)</label>
        <input type="text" id="dietary" name="dietary" placeholder="Vegetarian, allergies, etc." class="rsvp-input" />
      </div>

      <button type="submit" class="self-start inline-block bg-accent text-white font-display text-[22px] tracking-[0.1em] py-3 px-7 border-none cursor-pointer transition-opacity duration-100 hover:opacity-[0.88]">RSVP →</button>
      <div class="hidden [&.visible]:block text-[#cc0000] font-mono text-xs mt-2" id="rsvp-error">Something went wrong. Please try again.</div>
    </form>

    <div class="hidden [&.visible]:block" id="rsvp-thanks">
      <h2 class="font-display text-[2.5rem] leading-[1.1] mb-4">You're In.</h2>
      <p class="text-base italic text-ink-soft leading-[1.8] mb-8">
        Jeannine has been notified. The coals are warming.
      </p>
      <div class="border-site border-accent py-6 px-8 mb-8">
        <div class="font-mono text-[10px] tracking-[0.2em] uppercase text-accent mb-2">One More Thing</div>
        <p class="text-[0.95rem] italic text-ink-soft leading-[1.7] mb-4">
          While you're here — take a look at the food sign-up sheet.<br/>
          Grab a slot, claim a dish.<br/>
          We'd like to avoid a repeat of the year we only got 27 bags of Sour Cream and Onion Ruffles,
          one tube of Pringles, and a 20oz bottle of Diet Caffeine-free Mountain Dew.
        </p>
        <a href={EVENT.foodSignupUrl} class="inline-block bg-accent text-white font-display text-[20px] tracking-[0.1em] py-[10px] px-6 no-underline transition-opacity duration-100 hover:opacity-[0.88] hover:no-underline" target="_blank" rel="noopener noreferrer">Food Sign-Up →</a>
      </div>
    </div>

    <div class="hidden [&.visible]:block" id="rsvp-regrets">
      <h2 class="font-display text-[2.5rem] leading-[1.1] mb-4">We'll Miss You.</h2>
      <p class="text-base italic text-ink-soft leading-[1.8] mb-8">
        Thanks for letting us know. See you next season.
      </p>
    </div>
  </div>

  <script>
    const form = document.getElementById('rsvp-form');
    const thanks = document.getElementById('rsvp-thanks');
    const regrets = document.getElementById('rsvp-regrets');
    const error = document.getElementById('rsvp-error');
    const attendingFields = document.getElementById('rsvp-attending-fields');

    form.querySelectorAll('input[name="attending"]').forEach(radio => {
      radio.addEventListener('change', (e) => {
        attendingFields.classList.toggle('hidden', e.target.value !== 'yes');
      });
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      error.classList.remove('visible');

      const data = new FormData(form);
      const attending = data.get('attending') === 'yes';

      try {
        const res = await fetch('https://formspree.io/f/mqegryze', {
          method: 'POST',
          body: data,
          headers: { 'Accept': 'application/json' },
        });

        if (res.ok) {
          form.classList.add('hidden');
          (attending ? thanks : regrets).classList.add('visible');
        } else {
          error.classList.add('visible');
        }
      } catch {
        error.classList.add('visible');
      }
    });
  </script>
</Base>
