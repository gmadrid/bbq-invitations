---
import Base from '../layouts/Base.astro';
---
<Base title="RSVP">
  <style>
    .rsvp-wrap {
      max-width: 560px;
      margin: 0 auto;
    }

    .rsvp-eyebrow {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--ink-muted);
      margin-bottom: 1rem;
    }

    .rsvp-title {
      font-family: var(--font-display);
      font-size: 3rem;
      font-weight: 900;
      line-height: 1.1;
      margin-bottom: 1rem;
    }

    .rsvp-body {
      font-size: 1rem;
      color: var(--ink-soft);
      line-height: 1.8;
      margin-bottom: 2.5rem;
      font-style: italic;
    }

    .rsvp-details {
      border: var(--border-width) solid var(--border);
      border-top: 3px solid var(--accent);
      padding: 1.5rem 2rem;
      margin-bottom: 2.5rem;
      font-size: 0.95rem;
      line-height: 2;
    }

    .rsvp-details dt {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--ink-muted);
      margin-top: 1rem;
    }

    .rsvp-details dt:first-child { margin-top: 0; }

    .rsvp-details dd {
      color: var(--ink);
      margin: 0;
    }

    .rsvp-form {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .rsvp-field label {
      display: block;
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--ink-muted);
      margin-bottom: 0.4rem;
    }

    .rsvp-field input,
    .rsvp-field select,
    .rsvp-field textarea {
      width: 100%;
      font-family: var(--font-body);
      font-size: 1rem;
      padding: 0.6rem 0.75rem;
      border: var(--border-width) solid var(--border);
      background: var(--bg);
      color: var(--ink);
      outline: none;
    }

    .rsvp-field input:focus,
    .rsvp-field select:focus,
    .rsvp-field textarea:focus {
      border-color: var(--accent);
    }

    .rsvp-field textarea {
      resize: vertical;
      min-height: 80px;
    }

    .rsvp-radio-group {
      display: flex;
      gap: 1.5rem;
      margin-top: 0.3rem;
    }

    .rsvp-radio-group label {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-family: var(--font-body);
      font-size: 1rem;
      font-style: italic;
      color: var(--ink);
      letter-spacing: 0;
      text-transform: none;
      cursor: pointer;
    }

    .rsvp-radio-group input[type="radio"] {
      width: auto;
      accent-color: var(--accent);
    }

    .rsvp-submit {
      display: inline-block;
      background: var(--accent);
      color: #ffffff;
      font-family: var(--font-display);
      font-size: 22px;
      letter-spacing: 0.1em;
      padding: 12px 28px;
      border: none;
      cursor: pointer;
      align-self: flex-start;
      transition: opacity 0.1s;
    }

    .rsvp-submit:hover {
      opacity: 0.88;
    }
  </style>

  <div class="rsvp-wrap">
    <div class="rsvp-eyebrow">Boston Magic Lab · 2026</div>
    <h1 class="rsvp-title">RSVP</h1>
    <p class="rsvp-body">
      We'd love to know you're coming. Jeannine would also love to know —
      it helps with the coals.
    </p>

    <dl class="rsvp-details">
      <dt>When</dt>
      <dd>Sunday, May 17, 2026 · 1:00 PM</dd>
      <dt>Where</dt>
      <dd>70 Scituate Street, Arlington MA · Rear Garden</dd>
      <dt>Bring</dt>
      <dd>Food or drink to share · Coordination forthcoming</dd>
      <dt>BBQ Dad</dt>
      <dd>Jeannine</dd>
    </dl>

    <form class="rsvp-form" action="https://formspree.io/f/mqegryze" method="POST">
      <div class="rsvp-field">
        <label for="name">Your Name</label>
        <input type="text" id="name" name="name" required />
      </div>

      <div class="rsvp-field">
        <label>Are You Coming?</label>
        <div class="rsvp-radio-group">
          <label><input type="radio" name="attending" value="yes" required /> Yes</label>
          <label><input type="radio" name="attending" value="no" /> Regretfully, no</label>
        </div>
      </div>

      <div class="rsvp-field">
        <label for="guests">Total Guests (Including You)</label>
        <select id="guests" name="guests">
          <option value="1">1</option>
          <option value="2">2</option>
          <option value="3">3</option>
          <option value="4">4</option>
          <option value="5+">5+</option>
        </select>
      </div>

      <div class="rsvp-field">
        <label for="kids">Any Kids?</label>
        <select id="kids" name="kids">
          <option value="0">No kids</option>
          <option value="1">1</option>
          <option value="2">2</option>
          <option value="3">3</option>
          <option value="4+">4+</option>
        </select>
      </div>

      <div class="rsvp-field">
        <label for="dietary">Dietary Restrictions (Optional)</label>
        <input type="text" id="dietary" name="dietary" placeholder="Vegetarian, allergies, etc." />
      </div>

      <button type="submit" class="rsvp-submit">RSVP →</button>
    </form>
  </div>
</Base>
