---
import Base from '../layouts/Base.astro';
import { EVENT } from '../config';
---
<Base title="RSVP">
  <style>
    .rsvp-wrap {
      max-width: 560px;
      margin: 0 auto;
    }

    .rsvp-eyebrow {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--ink-muted);
      margin-bottom: 1rem;
    }

    .rsvp-title {
      font-family: var(--font-display);
      font-size: 3rem;
      font-weight: 900;
      line-height: 1.1;
      margin-bottom: 1rem;
    }

    .rsvp-body {
      font-size: 1rem;
      color: var(--ink-soft);
      line-height: 1.8;
      margin-bottom: 2.5rem;
      font-style: italic;
    }

    .rsvp-details {
      border: var(--border-width) solid var(--border);
      border-top: 3px solid var(--accent);
      padding: 1.5rem 2rem;
      margin-bottom: 2.5rem;
      font-size: 0.95rem;
      line-height: 2;
    }

    .rsvp-details dt {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--ink-muted);
      margin-top: 1rem;
    }

    .rsvp-details dt:first-child { margin-top: 0; }

    .rsvp-details dd {
      color: var(--ink);
      margin: 0;
    }

    .rsvp-form {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .rsvp-field label {
      display: block;
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--ink-muted);
      margin-bottom: 0.4rem;
    }

    .rsvp-field input,
    .rsvp-field select,
    .rsvp-field textarea {
      display: block;
      width: 100%;
      box-sizing: border-box;
      font-family: var(--font-body);
      font-size: 1rem;
      padding: 0.6rem 0.75rem;
      border: var(--border-width) solid var(--border);
      background: var(--bg);
      color: var(--ink);
      outline: none;
      -webkit-appearance: none;
      appearance: none;
    }

    .rsvp-field input:focus,
    .rsvp-field select:focus,
    .rsvp-field textarea:focus {
      border-color: var(--accent);
    }

    .rsvp-field textarea {
      resize: vertical;
      min-height: 80px;
    }

    .rsvp-fieldset {
      border: none;
      padding: 0;
      margin: 0;
    }

    .rsvp-legend {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--ink-muted);
      margin-bottom: 0.4rem;
      padding: 0;
    }

    .rsvp-radio-group {
      display: flex;
      gap: 1.5rem;
      margin-top: 0.3rem;
    }

    .rsvp-radio-group label {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-family: var(--font-body);
      font-size: 1rem;
      font-style: italic;
      color: var(--ink);
      letter-spacing: 0;
      text-transform: none;
      cursor: pointer;
    }

    .rsvp-radio-group input[type="radio"] {
      width: 16px;
      height: 16px;
      appearance: none;
      -webkit-appearance: none;
      border: var(--border-width) solid var(--border);
      border-radius: 50%;
      background: var(--bg);
      cursor: pointer;
      position: relative;
      flex-shrink: 0;
    }

    .rsvp-radio-group input[type="radio"]:checked {
      border-color: var(--accent);
      background: var(--accent);
    }

    .rsvp-radio-group input[type="radio"]:checked::after {
      content: '';
      position: absolute;
      top: 3px;
      left: 3px;
      width: 6px;
      height: 6px;
      background: #ffffff;
      border-radius: 50%;
    }

    .rsvp-submit {
      display: inline-block;
      background: var(--accent);
      color: #ffffff;
      font-family: var(--font-display);
      font-size: 22px;
      letter-spacing: 0.1em;
      padding: 12px 28px;
      border: none;
      cursor: pointer;
      align-self: flex-start;
      transition: opacity 0.1s;
    }

    .rsvp-submit:hover {
      opacity: 0.88;
    }

    .rsvp-thanks {
      display: none;
    }

    .rsvp-thanks.visible {
      display: block;
    }

    .rsvp-thanks-title {
      font-family: var(--font-display);
      font-size: 2.5rem;
      line-height: 1.1;
      margin-bottom: 1rem;
    }

    .rsvp-thanks-body {
      font-size: 1rem;
      font-style: italic;
      color: var(--ink-soft);
      line-height: 1.8;
      margin-bottom: 2rem;
    }

    .rsvp-thanks-food {
      border: var(--border-width) solid var(--accent);
      padding: 1.5rem 2rem;
      margin-bottom: 2rem;
    }

    .rsvp-thanks-food-label {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.5rem;
    }

    .rsvp-thanks-food-body {
      font-size: 0.95rem;
      font-style: italic;
      color: var(--ink-soft);
      line-height: 1.7;
      margin-bottom: 1rem;
    }

    .rsvp-thanks-food-link {
      display: inline-block;
      background: var(--accent);
      color: #ffffff;
      font-family: var(--font-display);
      font-size: 20px;
      letter-spacing: 0.1em;
      padding: 10px 24px;
      text-decoration: none;
      transition: opacity 0.1s;
    }

    .rsvp-thanks-food-link:hover {
      opacity: 0.88;
      text-decoration: none;
    }

    .rsvp-attending-fields {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .rsvp-attending-fields.hidden,
    .rsvp-form.hidden {
      display: none;
    }

    .rsvp-error {
      display: none;
      color: #cc0000;
      font-family: var(--font-mono);
      font-size: 12px;
      margin-top: 0.5rem;
    }

    .rsvp-error.visible {
      display: block;
    }
  </style>

  <div class="rsvp-wrap">
    <div class="rsvp-eyebrow">Boston Magic Lab · 2026</div>
    <h1 class="rsvp-title">RSVP</h1>
    <p class="rsvp-body">
      We'd love to know you're coming. Jeannine would also love to know —
      it helps with the coals.
    </p>

    <dl class="rsvp-details">
      <dt>When</dt>
      <dd>{EVENT.date}</dd>
      <dt>Where</dt>
      <dd>{EVENT.address} · {EVENT.addressLine2}</dd>
      <dt>Bring</dt>
      <dd>Food or drink to share · Coordination forthcoming</dd>
      <dt>BBQ Dad</dt>
      <dd>Jeannine</dd>
    </dl>

    <form class="rsvp-form" id="rsvp-form">
      <div class="rsvp-field">
        <label for="name">Your Name</label>
        <input type="text" id="name" name="name" required />
      </div>

      <fieldset class="rsvp-field rsvp-fieldset">
        <legend class="rsvp-legend">Are You Coming?</legend>
        <div class="rsvp-radio-group">
          <label><input type="radio" name="attending" value="yes" required /> Yes</label>
          <label><input type="radio" name="attending" value="no" /> Regretfully, no</label>
        </div>
      </fieldset>

      <div class="rsvp-attending-fields hidden" id="rsvp-attending-fields">
        <div class="rsvp-field">
          <label for="guests">Total Guests (Including You)</label>
          <select id="guests" name="guests">
            <option value="1">1</option>
            <option value="2">2</option>
            <option value="3">3</option>
            <option value="4">4</option>
            <option value="5+">5+</option>
          </select>
        </div>

        <div class="rsvp-field">
          <label for="kids">Any Kids?</label>
          <select id="kids" name="kids">
            <option value="0">No kids</option>
            <option value="1">1</option>
            <option value="2">2</option>
            <option value="3">3</option>
            <option value="4+">4+</option>
          </select>
        </div>
      </div>

      <div class="rsvp-field">
        <label for="dietary">Dietary Restrictions (Optional)</label>
        <input type="text" id="dietary" name="dietary" placeholder="Vegetarian, allergies, etc." />
      </div>

      <button type="submit" class="rsvp-submit">RSVP →</button>
      <div class="rsvp-error" id="rsvp-error">Something went wrong. Please try again.</div>
    </form>

    <div class="rsvp-thanks" id="rsvp-thanks">
      <h2 class="rsvp-thanks-title">You're In.</h2>
      <p class="rsvp-thanks-body">
        Jeannine has been notified. The coals are warming.
      </p>
      <div class="rsvp-thanks-food">
        <div class="rsvp-thanks-food-label">One More Thing</div>
        <p class="rsvp-thanks-food-body">
          While you're here — take a look at the food sign-up sheet.<br/>
          Grab a slot, claim a dish.<br/>
          We'd like to avoid a repeat of the year we only got 27 bags of Sour Cream and Onion Ruffles,
          one tube of Pringles, and a 20oz bottle of Diet Caffeine-free Mountain Dew.
        </p>
        <a href={EVENT.foodSignupUrl} class="rsvp-thanks-food-link" target="_blank" rel="noopener noreferrer">Food Sign-Up →</a>
      </div>
    </div>

    <div class="rsvp-thanks" id="rsvp-regrets">
      <h2 class="rsvp-thanks-title">We'll Miss You.</h2>
      <p class="rsvp-thanks-body">
        Thanks for letting us know. See you next season.
      </p>
    </div>
  </div>

  <script>
    const form = document.getElementById('rsvp-form');
    const thanks = document.getElementById('rsvp-thanks');
    const regrets = document.getElementById('rsvp-regrets');
    const error = document.getElementById('rsvp-error');
    const attendingFields = document.getElementById('rsvp-attending-fields');

    form.querySelectorAll('input[name="attending"]').forEach(radio => {
      radio.addEventListener('change', (e) => {
        attendingFields.classList.toggle('hidden', e.target.value !== 'yes');
      });
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      error.classList.remove('visible');

      const data = new FormData(form);
      const attending = data.get('attending') === 'yes';

      try {
        const res = await fetch('https://formspree.io/f/mqegryze', {
          method: 'POST',
          body: data,
          headers: { 'Accept': 'application/json' },
        });

        if (res.ok) {
          form.classList.add('hidden');
          (attending ? thanks : regrets).classList.add('visible');
        } else {
          error.classList.add('visible');
        }
      } catch {
        error.classList.add('visible');
      }
    });
  </script>
</Base>
