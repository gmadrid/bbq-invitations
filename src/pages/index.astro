---
import Base from '../layouts/Base.astro';
import { getPublishedInvitations } from '../utils';
import { photosPublished, EVENT } from '../config';

const published = await getPublishedInvitations();
const sorted = published.sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
const latest = sorted.length > 0 ? sorted[sorted.length - 1] : null;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---
<Base
  title="BBQ Invitations"
  ogImage={latest?.data.thumbnail}
  ogDescription="The same invitation to the same backyard BBQ — written in every style imaginable."
>
  <style>
    /* Hero background text — pure decorative, no Tailwind equivalent */
    .hero-bg {
      position: absolute;
      top: -30px;
      right: -20px;
      font-family: var(--font-display);
      font-size: min(220px, 28vw);
      line-height: 1;
      color: #f0f0f0;
      pointer-events: none;
      user-select: none;
      letter-spacing: -0.02em;
      z-index: 0;
    }

    /* Grid card hover effects — parent:hover affecting children */
    .grid-card:hover { background: #f0eaff; text-decoration: none; }
    .grid-card:hover .grid-thumb { background: var(--accent) !important; }
    .grid-card:hover .grid-thumb-label { color: #ffffff !important; }
    .grid-card:hover .grid-thumb img { transform: scale(1.05); }
    .grid-card:hover .grid-card-title { color: var(--accent); }
    .grid-card:hover .grid-card-date { color: #0a0a0a; }

    /* Hero latest hover effects */
    .hero-latest:hover .hero-latest-img {
      border-color: var(--accent);
      box-shadow: 0 0 0 2px var(--accent);
    }
    .hero-latest:hover .hero-latest-label { color: #0a0a0a; }
    .hero-latest:hover .hero-latest-title { color: var(--accent); }
  </style>

  <!-- Hero -->
  <section class="relative overflow-hidden py-20 pb-16 border-b-site border-border mb-0">
    <div class="hero-bg">BBQ</div>
    <div class="relative z-[1] flex justify-between items-center gap-8 max-sm:flex-col max-sm:items-start">
      <div class="flex-1">
        <span class="eyebrow">Boston Magic Lab · End of Season · 2026</span>
        <h1 class="font-display text-[clamp(56px,10vw,96px)] leading-[0.92] tracking-[0.01em] text-ink mb-6">
          One Barbecue.<br>
          <span class="text-accent block">Many Voices.</span>
        </h1>
        <p class="text-[1.05rem] italic text-ink-soft max-w-[440px] leading-[1.75]">
          The same invitation to the same backyard BBQ —
          written in every style I can manage.
        </p>
      </div>
      {latest?.data.thumbnail && (
        <a href={`${base}invitation/${latest.slug}`} class="hero-latest shrink-0 no-underline flex flex-col items-center gap-2 cursor-pointer max-sm:flex-row max-sm:w-full max-sm:gap-4">
          <span class="hero-latest-label font-mono text-[10px] tracking-[0.2em] uppercase text-accent">The Latest</span>
          <img src={`${base}${latest.data.thumbnail.replace(/^\//, '')}`} alt={latest.data.style} class="hero-latest-img w-[200px] aspect-[4/3] object-cover border-site border-border transition-[transform,border-color] duration-150 max-sm:w-[120px]" />
          <span class="hero-latest-title font-body italic text-[0.9rem] text-ink-soft">
            {latest.data.style}
          </span>
        </a>
      )}
    </div>
  </section>

  <!-- BBQ Info -->
  <section class="grid grid-cols-2 border-b-site border-border max-sm:grid-cols-1">
    <div class="py-10 pr-8 border-r-site border-border max-sm:border-r-0">
      <span class="eyebrow">The Actual Barbecue</span>
      <div class="font-display text-[42px] tracking-[0.04em] leading-none mb-7">The Details</div>

      <div class="mb-[1.1rem]">
        <div class="font-mono text-[9px] tracking-[0.22em] uppercase text-ink-muted mb-[3px]">When</div>
        <div class="text-base italic text-ink leading-[1.4]">{EVENT.date}</div>
      </div>
      <div class="mb-[1.1rem]">
        <div class="font-mono text-[9px] tracking-[0.22em] uppercase text-ink-muted mb-[3px]">Where</div>
        <div class="text-base italic text-ink leading-[1.4]">{EVENT.address}<br>{EVENT.addressLine2}</div>
      </div>
      <div class="mb-[1.1rem]">
        <div class="font-mono text-[9px] tracking-[0.22em] uppercase text-ink-muted mb-[3px]">Who</div>
        <div class="text-base italic text-ink leading-[1.4]">The Magic Lab & Friends</div>
      </div>
      <div class="mb-[1.1rem]">
        <div class="font-mono text-[9px] tracking-[0.22em] uppercase text-ink-muted mb-[3px]">Bring</div>
        <div class="text-base italic text-ink leading-[1.4]">Food or drink to share<br>
          <span class="font-mono text-[0.75rem] text-ink-muted not-italic">
            Coordination forthcoming
          </span>
        </div>
      </div>
    </div>

    <div class="py-10 pl-8 flex flex-col gap-6 max-sm:border-t-site max-sm:border-border max-sm:pl-0">
      {photosPublished ? (
        <>
          <span class="eyebrow">The BBQ Happened</span>
          <div class="font-display text-[32px] tracking-[0.04em] leading-none mb-4">See the Photos</div>
          <p class="text-[0.95rem] italic text-ink-soft leading-[1.7] mb-6">
            The smoke has cleared, the coals are cold,
            and the pictures are in.
          </p>
          <a href={EVENT.photosUrl} target="_blank" rel="noopener noreferrer" class="self-start inline-block bg-accent text-white font-display text-2xl tracking-[0.1em] py-3 px-7 no-underline transition-opacity duration-100 hover:opacity-[0.88] hover:no-underline">View & Add Photos →</a>
        </>
      ) : (
        <>
          <p class="text-[0.9rem] italic text-ink-soft leading-[1.7] border-l-[3px] border-accent pl-4">
            Jeannine will be presiding at the grill,
            as is her singular and irreplaceable custom.
          </p>
          <div class="mb-[1.1rem]">
            <div class="font-mono text-[9px] tracking-[0.22em] uppercase text-ink-muted mb-[3px]">Produced by</div>
            <div class="text-base italic text-ink leading-[1.4]">The Magic Lab Production Staff</div>
          </div>
          <a href={`${base}rsvp`} class="self-start mt-auto inline-block bg-accent text-white font-display text-2xl tracking-[0.1em] py-3 px-7 no-underline transition-opacity duration-100 hover:opacity-[0.88] hover:no-underline">RSVP →</a>
          <a href={EVENT.foodSignupUrl} class="self-start inline-block font-display text-2xl tracking-[0.1em] py-3 px-7 border-site border-accent text-accent no-underline mt-3 transition-opacity duration-100 hover:bg-[rgba(124,58,237,0.12)] hover:no-underline" target="_blank" rel="noopener noreferrer">Food Sign-Up Sheet →</a>
        </>
      )}
    </div>
  </section>

  <!-- Invitation Grid -->
  <div class="flex items-baseline justify-between py-5 pb-4 border-b border-border-light mb-0" id="styles">
    <div class="font-display text-[32px] tracking-[0.06em]">All Invitations</div>
    <div class="font-mono text-[10px] tracking-[0.1em] text-ink-muted">{sorted.length} invitations · 1 per day</div>
  </div>

  <div class="grid grid-cols-[repeat(auto-fill,minmax(220px,1fr))] border-l-site border-border mt-0">
    {sorted.map(inv => (
      <a href={`${base}invitation/${inv.slug}`} class="grid-card block border-r-site border-r-border border-b-site border-b-border text-ink no-underline transition-colors duration-[120ms]">
        <div
          class="grid-thumb aspect-[4/3] flex items-end p-3 transition-colors duration-[120ms] relative overflow-hidden"
          style={`background: ${inv.data.accentColor ?? '#1a1a1a'};`}
        >
          {inv.data.thumbnail
            ? <img src={`${base}${inv.data.thumbnail.replace(/^\//, '')}`} alt={inv.data.style} loading="lazy"
                class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-150" />
            : <span class="grid-thumb-label font-display text-[13px] tracking-[0.05em] leading-[1.2] transition-colors duration-[120ms] text-white">
                {inv.data.style}
              </span>
          }
        </div>
        <div class="py-3 px-[0.9rem] pb-4 border-t border-border-light">
          <div class="grid-card-title font-body italic text-[0.95rem] text-ink mb-1 leading-[1.3] transition-colors duration-[120ms]">{inv.data.style}</div>
          <div class="font-mono text-[9px] tracking-[0.05em] text-ink-muted leading-[1.5]">{inv.data.teaser}</div>
          <div class="grid-card-date font-mono text-[9px] text-accent mt-2 tracking-[0.08em]">
            {inv.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', timeZone: 'UTC' })}
          </div>
        </div>
      </a>
    ))}
  </div>
</Base>
