---
import Base from '../../layouts/Base.astro';
import { getPublishedInvitations } from '../../utils';

export async function getStaticPaths() {
  const published = await getPublishedInvitations();
  return published.map(inv => ({
    params: { slug: inv.slug },
    props: { inv },
  }));
}

const { inv } = Astro.props;
const { Content } = await inv.render();
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---
<Base
  title={inv.data.style}
  fonts={inv.data.fonts}
  accentColor={inv.data.accentColor}
  ogImage={inv.data.thumbnail}
  ogDescription={inv.data.teaser}
>
  <style>
    /* Text invitation content styles — targets rendered Markdown we can't add classes to */
    .inv-text-body p {
      @apply mb-[1.2em] text-[1.05rem] leading-[1.85] text-ink;
    }
    .inv-text-body em { @apply italic; }
    .inv-text-body strong { @apply font-semibold; }
    .inv-text-body h1, .inv-text-body h2, .inv-text-body h3 {
      @apply font-display font-black mt-8 mb-3 text-ink;
    }
    .inv-text-body h1 { @apply text-[2rem]; }
    .inv-text-body h2 { @apply text-2xl; }
    .inv-text-body h3 { @apply text-[1.2rem]; }
    .inv-text-body hr {
      @apply border-none border-t border-border my-8;
    }
    .inv-text-body blockquote {
      @apply border-l-2 border-accent pl-5 my-6 text-ink-soft italic;
    }
    .inv-text-body pre, .inv-text-body code {
      @apply font-mono text-[0.9rem] whitespace-pre-wrap bg-black/[0.04] px-[0.4em] py-[0.15em];
    }
    .inv-text-body pre {
      @apply py-5 px-6 overflow-x-auto leading-[1.6];
    }
  </style>

  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 font-mono text-[0.7rem] tracking-[0.15em] uppercase text-ink-muted mb-12" aria-label="Breadcrumb">
    <a href={`${base}#styles`} class="text-ink-muted hover:text-accent hover:no-underline">All Invitations</a>
    <span class="text-border">›</span>
    <span>{inv.data.style}</span>
  </nav>

  <!-- Header -->
  <div class="mb-12">
    <div class="font-mono text-[0.65rem] tracking-[0.3em] uppercase text-ink-muted mb-3">Boston Magic Lab · End of Season BBQ · 2026</div>
    <h1 class="font-display text-[clamp(2rem,5vw,3.5rem)] font-black leading-[1.1] text-ink mb-3">{inv.data.style}</h1>
    <div class="font-mono text-[0.7rem] tracking-[0.15em] uppercase text-ink-muted">
      {inv.data.date.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' })}
    </div>
  </div>

  <hr class="border-none border-t border-border my-8" />

  <!-- Content -->
  {inv.data.type === 'text'
    ? (
      <div class="inv-text-body max-w-[680px]">
        <Content />
      </div>
    )
    : (
      <div class="w-full">
        <Content />
      </div>
    )
  }

  <!-- Footer nav -->
  <div class="flex justify-between mt-16 pt-8 border-t border-border font-mono text-[0.75rem] tracking-[0.1em] uppercase text-ink-muted">
    <a href={`${base}#styles`} class="text-ink-muted flex items-center gap-2 hover:text-accent hover:no-underline">← All Invitations</a>
    <a href={`${base}rsvp`} class="text-ink-muted flex items-center gap-2 hover:text-accent hover:no-underline">RSVP →</a>
  </div>
</Base>
