---
import Base from '../layouts/Base.astro';

// Inline styles вҖ” Astro scoped styles don't reach set:html content
const S = (style: string, t: string) => `<span style="${style}">${t}</span>`;
const s1 = (t: string) => S('color:#e74c3c', t);
const s2 = (t: string) => S('color:#e67e22', t);
const s3 = (t: string) => S('color:#f1c40f', t);
const s4 = (t: string) => S('color:#2ecc71', t);
const s5 = (t: string) => S('color:#3498db', t);
const s6 = (t: string) => S('color:#9b59b6', t);
const g = (t: string) => S('color:#f5c518;text-shadow:0 0 10px rgba(245,197,24,0.4)', t);
const w = (t: string) => S('color:#e8d5a3', t);
const b = (t: string) => S('color:#fff;text-shadow:0 0 6px rgba(255,255,255,0.3)', t);
const d = (t: string) => S('color:#6b4f1d', t);
const f = (t: string) => S('color:#e8d5a3', t);
const gd = (t: string) => S('color:#f5c518', t);
const bl = (t: string) => S('color:#f5c518;text-shadow:0 0 4px rgba(245,197,24,0.6)', t);

const bulbs = ` ${bl('в—Ҹ')} ${d('в—Ӣ')} ${bl('в—Ҹ')} ${d('в—Ӣ')} ${bl('в—Ҹ')} ${d('в—Ӣ')} ${bl('в—Ҹ')} ${d('в—Ӣ')} ${bl('в—Ҹ')} ${d('в—Ӣ')} ${bl('в—Ҹ')} ${d('в—Ӣ')} ${bl('в—Ҹ')} ${d('в—Ӣ')} ${bl('в—Ҹ')} ${d('в—Ӣ')} ${bl('в—Ҹ')} ${d('в—Ӣ')} ${bl('в—Ҹ')} ${d('в—Ӣ')} ${bl('в—Ҹ')} ${d('в—Ӣ')} ${bl('в—Ҹ')}`;

const art = [
  bulbs,
  '',
  g('     в–Ҳв–Ҳ  в–Ҳв–Ҳ в–Ҳв–Ҳв–Ҳ  в–Ҳв–Ҳ  в–Ҳв–Ҳв–Ҳв–Ҳ в–Ҳв–Ҳ     в–Ҳв–Ҳв–Ҳв–Ҳ'),
  g('     в–Ҳв–Ҳ  в–Ҳв–Ҳ в–Ҳв–Ҳв–Ҳв–Ҳ в–Ҳв–Ҳ в–Ҳв–Ҳ    в–Ҳв–Ҳ     в–Ҳв–Ҳ'),
  g('     в–Ҳв–Ҳ  в–Ҳв–Ҳ в–Ҳв–Ҳ в–Ҳв–Ҳв–Ҳв–Ҳ в–Ҳв–Ҳ    в–Ҳв–Ҳ     в–Ҳв–Ҳв–Ҳв–Ҳ'),
  g('     в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳ в–Ҳв–Ҳ  в–Ҳв–Ҳв–Ҳ  в–Ҳв–Ҳв–Ҳв–Ҳ в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳ  в–Ҳв–Ҳв–Ҳв–Ҳ'),
  '',
  g('         в–Ҳв–Ҳ  в–Ҳв–Ҳ  в–Ҳв–Ҳв–Ҳв–Ҳ  в–Ҳв–Ҳ  в–Ҳв–Ҳ'),
  g('          в–Ҳв–Ҳв–Ҳв–Ҳ  в–Ҳв–Ҳ  в–Ҳв–Ҳ в–Ҳв–Ҳ в–Ҳв–Ҳ'),
  g('           в–Ҳв–Ҳ   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳ в–Ҳв–Ҳв–Ҳв–Ҳ'),
  g('           в–Ҳв–Ҳ   в–Ҳв–Ҳ  в–Ҳв–Ҳ в–Ҳв–Ҳ в–Ҳв–Ҳ'),
  '',
  w('             ~ ~ ~ and his ~ ~ ~'),
  '',
  b('       M A G I C   C O M E B A C K'),
  '',
  '',
  f('                  *  В·  *  В·  *'),
  f('                     в•ӯв”Җв”Җв”Җв•®'),
  f('                     в”ӮВ° В°в”Ӯ'),
  f('                     в•°в”Җв”¬в”Җв•Ҝ'),
  f('                в•ӯв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв•®'),
  f('               в•ұ      в”Ӯ      в•І'),
  f('              в•ұ       в”Ӯ       в•І') + s1('в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ'),
  f('                      в”Ӯ        ') + s2('в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ'),
  f('                      в”Ӯ         ') + s3('в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ'),
  f('                     в•ұ в•І         ') + s4('в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ'),
  f('                    в•ұ   в•І         ') + s5('в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ'),
  f('                   в•ұ     в•І         ') + s6('в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ'),
  '',
  '',
  d('        в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ вҳ… вҳ… вҳ… в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ'),
  '',
  `        ${w('Thurs, May 14')} ${d('В·В·В·В·В·В·В·')} ${gd('9:15p')} ${w('(post Lab)')}`,
  `        ${w('  Sat, May 16')} ${d('В·В·В·В·В·В·В·')} ${gd('7:05p')}`,
  `        ${w('  Sun, May 17')} ${d('В·В·В·В·В·В·В·')} ${gd('8:10p')} ${w('(post BBQ)')}`,
  '',
  d('        в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ вҳ… вҳ… вҳ… в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ'),
  '',
  `         ${w('THE ROCKWELL')} ${d('В·')} ${w('DAVIS SQUARE')}`,
  w('              SOMERVILLE, MA'),
  '',
  `       ${d('в•¶в”Җв”Җ')} ${gd('Boston Fringe Festival')} ${d('в”Җв”Җв•ҙ')}`,
  '',
  bulbs,
].join('\n');
---
<Base
  title="Uncle Yak and his Magic Comeback"
  fonts={['Fira Code:wght@400;700']}
  accentColor="#d4a017"
  ogImage="/images/uncle-yak-poster.jpg"
  ogDescription="Boston Fringe Festival вҖ” The Rockwell, Davis Square вҖ” May 14, 16, 17"
>
  <style>
    .inv-nav, .inv-header, .inv-divider, .inv-footer-nav { display: none; }

    .uy-wrap {
      max-width: 640px;
      margin: 0 auto;
      background: #0d0906;
      border: 3px solid #b8860b;
      padding: 4px;
    }

    .uy-inner {
      border: 1px solid #6b4f1d;
      padding: 24px 16px;
      overflow: hidden;
      display: flex;
      justify-content: center;
    }

    .uy-art {
      font-family: 'Fira Code', 'Courier New', monospace;
      font-size: clamp(0.45rem, 1.2vw, 0.72rem);
      line-height: 1.45;
      color: #c9a84c;
      margin: 0;
    }

    @media (max-width: 500px) {
      .uy-art { font-size: 0.38rem; line-height: 1.3; }
      .uy-inner { padding: 16px 8px; }
    }
  </style>

  <div class="uy-wrap">
    <div class="uy-inner">
      <pre class="uy-art" set:html={art} />
    </div>
  </div>
</Base>
